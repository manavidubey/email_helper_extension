# LiteLLM Configuration
# One of the following providers is required. 
# You can get keys from their respective websites.

# GROQ_API_KEY=your_groq_key
# OPENROUTER_API_KEY=your_openrouter_key
# TOGETHERAI_API_KEY=your_together_key
# HUGGINGFACE_API_KEY=your_hf_key

# Model to use (LiteLLM format, e.g., groq/llama3-8b-8192)
LLM_MODEL=groq/llama3-8b-8192
